{
  "name": "ai-companions",
  "version": "1.0.0",
  "private": true,
  "workspaces": [
    "shared",
    "server"
  ],
  "scripts": {
    "server:dev": "npm run dev --workspace=server",
    "shared:build": "npm run build --workspace=shared",
    "server:build": "npm run build --workspace=server",
    "postinstall": "npm run shared:build",
    "build": "npm run shared:build && npm run server:build",
    "seed": "npm run seed --workspace=server"
  }
}
